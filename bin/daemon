#!/usr/bin/env python3

import logging
import os
import socket

from epa_orchestrator.daemon_handler import handle_daemon_request
from epa_orchestrator.log import setup_logging

SOCKET_FILENAME = "epa.sock"
SOCKET_PATH = os.path.join(os.environ["SNAP_DATA"], "data", SOCKET_FILENAME)


def main():
    setup_logging()

    os.makedirs(os.path.dirname(SOCKET_PATH), exist_ok=True)

    if os.path.exists(SOCKET_PATH):
        os.remove(SOCKET_PATH)

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as server:
        server.bind(SOCKET_PATH)
        os.chmod(SOCKET_PATH, 0o666)
        server.listen(1)
        logging.info(f"EPA orchestrator daemon listening on {SOCKET_PATH}")

        while True:
            conn, _ = server.accept()
            with conn:
                data = conn.recv(1024)
                if not data:
                    continue
                response_bytes = handle_daemon_request(data)
                conn.sendall(response_bytes)


if __name__ == "__main__":
    main()
